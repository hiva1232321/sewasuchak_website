generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  name       String
  phone      String?
  role       String   @default("CITIZEN") // CITIZEN, OFFICIAL, ADMIN
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  issues     Issue[]
  votes      Vote[]
  comments   Comment[]
}

model Otp {
  id        String   @id @default(uuid())
  email     String
  code      String
  type      String   // SIGNUP, REPORT
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Issue {
  id          String    @id @default(uuid())
  title       String
  description String
  category    String // Road, Water, Electricity, etc.
  latitude    Float
  longitude   Float
  address     String?
  status          String      @default("REPORTED") // REPORTED, ACKNOWLEDGED, IN_PROGRESS, RESOLVED, REJECTED
  priority        String      @default("NORMAL") // LOW, NORMAL, HIGH, CRITICAL
  imageUrl        String?
  videoUrl        String?
  authorId        String
  author          User        @relation(fields: [authorId], references: [id])
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  votes           Vote[]
  comments        Comment[]
  media           Media[]
  
  // Government Portal Fields
  departmentId    String?
  department      Department? @relation(fields: [departmentId], references: [id])
  rejectionReason String?
  proofImageUrl   String?
  govNote         String?
}

model Media {
  id        String   @id @default(uuid())
  url       String
  type      String   // IMAGE, VIDEO
  issueId   String
  issue     Issue    @relation(fields: [issueId], references: [id])
  createdAt DateTime @default(now())
}

model Vote {
  id        String   @id @default(uuid())
  userId    String
  issueId   String
  user      User     @relation(fields: [userId], references: [id])
  issue     Issue    @relation(fields: [issueId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, issueId]) // One vote per user per issue
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  userId    String
  issueId   String
  user      User     @relation(fields: [userId], references: [id])
  issue     Issue    @relation(fields: [issueId], references: [id])
  createdAt DateTime @default(now())
}

model Department {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  logoUrl     String?
  projects    Project[]
  issues      Issue[]
  createdAt   DateTime  @default(now())
}

model Project {
  id           String          @id @default(uuid())
  title        String
  description  String
  budget       Float
  spentAmount  Float           @default(0)
  startDate    DateTime
  endDate      DateTime?
  status       String          @default("PLANNED") // PLANNED, ONGOING, COMPLETED, DELAYED
  latitude     Float?
  longitude    Float?
  address      String?
  departmentId String
  department   Department      @relation(fields: [departmentId], references: [id])
  updates      ProjectUpdate[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model ProjectUpdate {
  id          String   @id @default(uuid())
  title       String
  description String
  imageUrl    String?
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  createdAt   DateTime @default(now())
}
